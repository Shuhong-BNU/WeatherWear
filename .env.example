# Default LLM provider
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_ID=
LLM_PROVIDER=openai_compatible
LLM_NAME=default
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=60

# Optional alternate provider
ALT_LLM_API_KEY=
ALT_LLM_BASE_URL=
ALT_LLM_MODEL_ID=
ALT_LLM_PROVIDER=openai_compatible
ALT_LLM_NAME=alternate
ALT_LLM_TEMPERATURE=0.2
ALT_LLM_TIMEOUT_SECONDS=60

# Which provider name should be used by default: default / alternate
DEFAULT_LLM_PROVIDER=default

# OpenWeather
OPENWEATHER_API_KEY=

# Map defaults
MAP_PROVIDER=osm
BAIDU_MAP_AK=
OSM_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
OSM_ATTRIBUTION=&copy; OpenStreetMap contributors
MAP_DEFAULT_CENTER_LAT=39.9042
MAP_DEFAULT_CENTER_LON=116.4074
MAP_DEFAULT_ZOOM=9
