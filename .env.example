# 默认 LLM Provider
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_ID=
LLM_PROVIDER=openai_compatible
LLM_NAME=default
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=60

# 可选备用 Provider
ALT_LLM_API_KEY=
ALT_LLM_BASE_URL=
ALT_LLM_MODEL_ID=
ALT_LLM_PROVIDER=openai_compatible
ALT_LLM_NAME=alternate
ALT_LLM_TEMPERATURE=0.2
ALT_LLM_TIMEOUT_SECONDS=60

# 指定默认启用哪个 Provider 名称，可选值如 default / alternate
DEFAULT_LLM_PROVIDER=default

# OpenWeather
OPENWEATHER_API_KEY=
